{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=quickorder;Username=postgres;Password=postgres"
  },
  "Sqs": {
    "Region": "us-east-1",
    "QueueUrl": "REPLACE_WITH_YOUR_SQS_QUEUE_URL"
  },
  "S3": {
    "BucketName": "REPLACE_WITH_YOUR_S3_BUCKET",
    "Region": "us-east-1"
  },
  "Cors": {
    "AllowedOrigins": [ "*" ]
  },
  "RateLimiting": {
    "PermitLimit": 1000,
    "WindowSeconds": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore": "Information",
        "Microsoft.AspNetCore": "Information"
      }
    }
  }
}
