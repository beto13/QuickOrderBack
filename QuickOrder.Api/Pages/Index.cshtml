@page
@model QuickOrder.Api.Pages.IndexModel
@{
    ViewData["Title"] = "Cocina";
    ViewData["Page"] = "Kitchen";
}

<style>
    .board {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        padding: 1.5rem;
    }

    .column h2 {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #9ca3af;
        margin-bottom: 0.75rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid #2d2d2d;
    }

    .column-pending h2   { color: #f59e0b; border-color: #f59e0b44; }
    .column-prep h2      { color: #3b82f6; border-color: #3b82f644; }
    .column-ready h2     { color: #22c55e; border-color: #22c55e44; }

    .cards { display: flex; flex-direction: column; gap: 0.75rem; }

    .card {
        background: #1e1e1e;
        border-radius: 8px;
        padding: 1rem;
        border-left: 4px solid #374151;
        animation: slideIn 0.3s ease;
    }

    .card.pending  { border-color: #f59e0b; }
    .card.inprep   { border-color: #3b82f6; }
    .card.ready    { border-color: #22c55e; }

    @@keyframes slideIn {
        from { opacity: 0; transform: translateY(-8px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.6rem;
    }

    .table-badge {
        background: #374151;
        border-radius: 4px;
        padding: 0.2rem 0.6rem;
        font-size: 0.8rem;
        font-weight: 700;
    }

    .order-id { font-size: 0.75rem; color: #6b7280; }

    .items { list-style: none; margin-bottom: 0.75rem; }

    .items li {
        font-size: 0.9rem;
        padding: 0.2rem 0;
        color: #d1d5db;
        display: flex;
        gap: 0.4rem;
    }

    .items li .qty { color: #f59e0b; font-weight: 700; min-width: 1.2rem; }

    .notes {
        font-size: 0.8rem;
        color: #9ca3af;
        font-style: italic;
        margin-bottom: 0.75rem;
    }

    .card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.5rem;
    }

    .time { font-size: 0.75rem; color: #6b7280; }
    .actions { display: flex; gap: 0.5rem; }

    .btn {
        border: none;
        border-radius: 5px;
        padding: 0.35rem 0.75rem;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.15s;
    }
    .btn:hover { opacity: 0.8; }
    .btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .btn-advance { background: #3b82f6; color: #fff; }
    .btn-cancel  { background: #374151; color: #9ca3af; }

    .empty {
        color: #4b5563;
        font-size: 0.85rem;
        text-align: center;
        padding: 2rem 0;
    }
</style>

<div class="board">
    <div class="column column-pending">
        <h2>Pendientes</h2>
        <div class="cards" id="col-Pending"></div>
    </div>
    <div class="column column-prep">
        <h2>En preparación</h2>
        <div class="cards" id="col-InPreparation"></div>
    </div>
    <div class="column column-ready">
        <h2>Listos</h2>
        <div class="cards" id="col-Ready"></div>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    const orders = {};

    const statusNext  = { 'Pending': 'InPreparation', 'InPreparation': 'Ready', 'Ready': 'Delivered' };
    const statusLabel = { 'Pending': 'Tomar', 'InPreparation': 'Listo', 'Ready': 'Entregar' };
    const colMap      = { 'Pending': 'col-Pending', 'InPreparation': 'col-InPreparation', 'Ready': 'col-Ready' };
    const cardClass   = { 'Pending': 'pending', 'InPreparation': 'inprep', 'Ready': 'ready' };

    function timeAgo(dateStr) {
        const diff = Math.floor((Date.now() - new Date(dateStr)) / 1000);
        if (diff < 60) return `${diff}s`;
        if (diff < 3600) return `${Math.floor(diff / 60)}min`;
        return `${Math.floor(diff / 3600)}h`;
    }

    function renderCard(order) {
        const next = statusNext[order.status];
        const col  = colMap[order.status];
        if (!col) return;

        const card = document.createElement('div');
        card.className = `card ${cardClass[order.status]}`;
        card.id = `order-${order.id}`;
        card.innerHTML = `
            <div class="card-header">
                <span class="table-badge">Mesa ${order.tableNumber}</span>
                <span class="order-id">#${order.id}</span>
            </div>
            <ul class="items">
                ${order.items.map(i => `<li><span class="qty">${i.quantity}x</span>${i.productName}${i.notes ? ` <em style="color:#6b7280">(${i.notes})</em>` : ''}</li>`).join('')}
            </ul>
            ${order.notes ? `<div class="notes">📝 ${order.notes}</div>` : ''}
            <div class="card-footer">
                <span class="time">${timeAgo(order.createdAt)}</span>
                <div class="actions">
                    <button class="btn btn-cancel" onclick="cancelOrder(${order.id})">Cancelar</button>
                    ${next ? `<button class="btn btn-advance" onclick="advanceOrder(${order.id}, '${next}')">${statusLabel[order.status]}</button>` : ''}
                </div>
            </div>`;
        document.getElementById(col).prepend(card);
    }

    function removeCard(id) { document.getElementById(`order-${id}`)?.remove(); }

    function refreshEmpty() {
        Object.values(colMap).forEach(colId => {
            const col = document.getElementById(colId);
            if (col.querySelectorAll('.card').length === 0) {
                if (!col.querySelector('.empty')) col.innerHTML = '<p class="empty">Sin pedidos</p>';
            } else {
                col.querySelector('.empty')?.remove();
            }
        });
    }

    async function advanceOrder(id, newStatus) {
        document.querySelector(`#order-${id} .btn-advance`).disabled = true;
        await fetch(`/api/orders/${id}/status`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: newStatus })
        });
    }

    async function cancelOrder(id) {
        document.querySelector(`#order-${id} .btn-cancel`).disabled = true;
        await fetch(`/api/orders/${id}/status`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: 'Cancelled' })
        });
    }

    async function loadOrders() {
        const res = await (await fetch('/api/orders/active')).json();
        (res.data ?? []).forEach(o => { orders[o.id] = o; renderCard(o); });
        refreshEmpty();
    }

    const hub = new signalR.HubConnectionBuilder()
        .withUrl('/hubs/orders')
        .withAutomaticReconnect()
        .build();

    hub.on('NewOrder', order => {
        orders[order.id] = order;
        removeCard(order.id);
        renderCard(order);
        refreshEmpty();
    });

    hub.on('OrderStatusChanged', ({ orderId, status }) => {
        removeCard(orderId);
        if (orders[orderId]) {
            orders[orderId].status = status;
            if (colMap[status]) renderCard(orders[orderId]);
        }
        refreshEmpty();
    });

    hub.onreconnecting(() => { document.getElementById('status-dot').className = ''; document.getElementById('connection-label').textContent = 'Reconectando...'; });
    hub.onreconnected(() =>  { document.getElementById('status-dot').className = 'connected'; document.getElementById('connection-label').textContent = 'Conectado'; });
    hub.onclose(() =>        { document.getElementById('status-dot').className = ''; document.getElementById('connection-label').textContent = 'Desconectado'; });

    async function startHub() {
        await hub.start();
        document.getElementById('status-dot').className = 'connected';
        document.getElementById('connection-label').textContent = 'Conectado';
    }

    loadOrders();
    startHub();

    setInterval(() => {
        Object.values(orders).forEach(o => {
            const el = document.querySelector(`#order-${o.id} .time`);
            if (el) el.textContent = timeAgo(o.createdAt);
        });
    }, 60000);
</script>
}
